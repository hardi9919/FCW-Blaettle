                <script>
                    $(document).ready(function () {
                        $(document.body).on('hidden.bs.modal', function () {
                            $('#modalembeds').removeData('bs.modal');
                            $("#modalembeds .modal-content").html('');
                        });

                        $(document).on('click', '.openEmbed', function (e) {
                            var target = $(this).attr("href");

                            // load the url and show modal on success
                            $("#modalembeds .modal-content").load(target, function () {
                                $("#modalembeds").modal("show");
                            });

                            return false;
                        });

                        $(document).on('click', '.yp-grid-mode-cover-content-share-btn', function () {
                            if ($(this).parent('.btn-group').parent('.yp-grid-mode-cover-content-btn-container').find('.yp-grid-mode-cover-content-share-container-outer').css('display') == 'none') {
                                $('.yp-grid-mode-cover-content-share-container-outer').hide();
                                $(this).parent('.btn-group').parent('.yp-grid-mode-cover-content-btn-container').find('.yp-grid-mode-cover-content-share-container-outer').toggle();
                            } else {
                                $('.yp-grid-mode-cover-content-share-container-outer').hide();
                            }
                        });

                        $(document).on('mouseleave', '.yp-grid-mode-cover-content-share-container-outer', function () {
                            $(this).toggle();
                        });
                    });
                </script>
